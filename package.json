{
  "name": "youtube-mirror",
  "private": true,
  "version": "0.0.1",
  "description": "Mirror a YouTube channel's videos, community posts, and comments to Bluesky via Cloudflare Workers",
  "type": "module",
  "scripts": {
    "build": "for c in wrangler.mirror-*.jsonc; do wrangler deploy --config $c --dry-run --outdir=dist || exit 1; done",
    "dev": "wrangler dev --config wrangler.mirror-channel.jsonc",
    "deploy": "for c in wrangler.mirror-*.jsonc; do wrangler deploy --config $c || exit 1; done",
    "lint": "eslint . --quiet --max-warnings 0",
    "lint:fix": "eslint . --fix --quiet --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --config wrangler.mirror-channel.jsonc",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:all": "npm run lint -s && npm run typecheck -s && npm run test -s && npm run build -s",
    "prepare": "node -e \"process.env.MSYS_NO_PATHCONV='1';import('husky').then(m=>process.stdout.write(m.default()))\" --input-type=module"
  },
  "dependencies": {
    "@atproto/api": "^0.19.3",
    "compromise": "^14.15.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.1.0",
    "eslint": "^9.32.0",
    "husky": "^9.1.7",
    "playwright": "^1.61.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.73.0"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
