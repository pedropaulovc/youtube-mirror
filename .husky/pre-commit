#!/bin/bash

# Block commits to main and reserved worktree branches (A, B, C, D, E, F, G)
# Use feature branches and PRs instead

branch_name=$(git symbolic-ref --short HEAD 2>/dev/null)

case "$branch_name" in
    main|A|B|C|D|E|F|G)
        echo "ERROR: Direct commits to branch '$branch_name' are not allowed."
        echo ""
        echo "Create a feature branch instead:"
        echo "  git checkout -b feature/your-feature-name"
        echo ""
        exit 1
        ;;
esac

exit 0
